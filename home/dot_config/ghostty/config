# font-family = "FiraCode Nerd Font Mono"
font-family = "JetBrains Mono Nerd Font"
# font-family = "MesloLGL Nerd Font Mono"
font-size = 18

theme = "Catppuccin Mocha"
auto-update = download

keybind = global:cmd+grave_accent=toggle_quick_terminal
# No shift+enter or cmd+enter overrides needed — kitty keyboard protocol
# lets nvim and other modern TUI apps (Claude Code) recognize these natively.
# Tabs and titlebar
macos-titlebar-style = tabs
window-save-state = always

# Cmd+S sends Ctrl+S for Neovim save
keybind = cmd+s=text:\x13

# Tab navigation
keybind = cmd+j=previous_tab
keybind = cmd+k=next_tab
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true

# Split appearance (Catppuccin Mocha Overlay0)
split-divider-color = #6c7086

# Pane navigation — cmd+h/l for splits, matches cmd+j/k for tabs
# (ctrl+h/l reserved for nvim window nav, alt+h/l for aerospace)
keybind = cmd+h=goto_split:left
keybind = cmd+l=goto_split:right

# Pane resizing (vim-style)
keybind = ctrl+shift+h=resize_split:left,50
keybind = ctrl+shift+j=resize_split:down,50
keybind = ctrl+shift+k=resize_split:up,50
keybind = ctrl+shift+l=resize_split:right,50
keybind = ctrl+shift+semicolon=equalize_splits

